#!/usr/bin/env bash
set -euo pipefail

PROJECT_NAME="${PROJECT_NAME:-agroclimR_app}"
VERSION="${VERSION:-0.1.0}"
DOCKERHUB_USERNAME="${DOCKERHUB_USERNAME:-dockerhub_username}"
IMAGE_PREFIX="${IMAGE_PREFIX:-agroclimr-app}"

usage() {
  cat <<'USAGE'
Usage:
  crop-run <model> <input_folder> [extra_args]
  crop-run --help

Models:
  dssat
  oryza
  aquacrop

Examples:
  crop-run oryza ~/forecast/test/oryza
  crop-run dssat ~/forecast/test/dssat B DSSBatch.v47
  crop-run aquacrop ~/forecast/test/aquacrop

Variables:
  DOCKERHUB_USERNAME  Docker Hub user or namespace.
  VERSION             Image version. Default: 0.1.0
  IMAGE_PREFIX        Image prefix. Default: agroclimr-app
USAGE
}

die() {
  echo "crop-run: error: $*" >&2
  exit 1
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || die "Could not find '$1' in PATH."
}

absolute_path() {
  local path="$1"
  if command -v realpath >/dev/null 2>&1; then
    realpath "$path"
  else
    (cd "$path" && pwd -P)
  fi
}

image_for_model() {
  local model="$1"
  case "$model" in
    dssat|oryza|aquacrop)
      printf '%s/%s-%s:%s\n' "$DOCKERHUB_USERNAME" "$IMAGE_PREFIX" "$model" "$VERSION"
      ;;
    *)
      return 1
      ;;
  esac
}

main() {
  if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    usage
    exit 0
  fi

  [[ $# -ge 2 ]] || {
    usage >&2
    exit 2
  }

  local model="$1"
  local input_dir="$2"
  shift 2

  require_command docker
  docker info >/dev/null 2>&1 || die "Docker is unavailable. On WSL, check Docker Desktop and WSL2 integration."

  [[ -d "$input_dir" ]] || die "Input folder does not exist: $input_dir"

  local workdir
  workdir="$(absolute_path "$input_dir")"

  local image
  image="$(image_for_model "$model")" || die "Unsupported model: $model. Use dssat, oryza, or aquacrop."

  echo "Model: $model"
  echo "Image: $image"
  echo "Workdir: $workdir -> /work"

  docker run --rm \
    --volume "${workdir}:/work" \
    --workdir /work \
    "$image" "$@"
}

main "$@"
